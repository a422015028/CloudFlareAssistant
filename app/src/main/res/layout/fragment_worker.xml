<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/deployCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/deployCardHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="部署 Worker 脚本"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/deployCardArrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_down"
                            android:rotation="0" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/deployCardContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Worker 名称"
                            app:boxBackgroundMode="outline"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_marginBottom="10dp">

                            <AutoCompleteTextView
                                android:id="@+id/workerNameEdit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="脚本文件(仅支持：.js)"
                            app:boxBackgroundMode="outline"
                            app:endIconMode="custom"
                            app:endIconDrawable="@android:drawable/ic_menu_search"
                            android:layout_marginBottom="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/filePathEdit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:focusable="false"
                                android:clickable="true" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="默认兼容日期 2026-06-16"
                            app:placeholderText="输入格式：2026-06-16"
                            app:boxBackgroundMode="outline"
                            android:layout_marginBottom="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/compatibilityDateEdit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/selectFileBtn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="选择文件"
                            android:layout_marginBottom="12dp"
                            style="@style/Widget.Material3.Button.OutlinedButton" />

                        <Button
                            android:id="@+id/uploadBtn"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:text="部署脚本"
                            android:textSize="14sp"
                            style="@style/Widget.Material3.Button" />

                        <ProgressBar
                            android:id="@+id/uploadProgress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:visibility="gone"
                            style="?android:attr/progressBarStyleHorizontal" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Scripts List Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="4dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="脚本"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        
                        <Button
                            android:id="@+id/cleanupDeploymentsBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="管理版本"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/toggleSelectionModeBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="管理脚本"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/refreshBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="刷新"
                            style="@style/Widget.Material3.Button.TextButton" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/selectionActionsLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/selectionStatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="已选择 0 个脚本"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />

                        <Button
                            android:id="@+id/selectAllBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="全选"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/batchDeleteBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="批量删除"
                            style="@style/Widget.Material3.Button" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/scriptsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <TextView
                        android:id="@+id/emptyText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无脚本"
                        android:textAlignment="center"
                        android:padding="24dp"
                        android:textColor="?android:textColorSecondary"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
