<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="规则用于控制网络流量，支持 DNS、HTTP 和网络层匹配。"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- 快速模板 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="快速模板"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/templateBlockBtn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="阻止域名" />

            <Button
                android:id="@+id/templateAllowBtn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="允许域名" />

            <Button
                android:id="@+id/templateSafeBtn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="安全搜索" />

        </LinearLayout>

        <!-- 规则名称 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="规则名称 *">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ruleNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 规则类型 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="规则类型"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="DNS: 匹配域名查询 | HTTP: 匹配网站访问 | 网络: 匹配 IP 和端口"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary" />

        <Spinner
            android:id="@+id/ruleTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- 动作 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="动作"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="允许: 放行流量 | 阻止: 拒绝访问 | 安全搜索: 过滤不良内容"
            android:textSize="11sp"
            android:textColor="?android:attr/textColorSecondary" />

        <Spinner
            android:id="@+id/actionSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <!-- DNS 规则字段 -->
        <LinearLayout
            android:id="@+id/dnsFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DNS 规则"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="匹配域名查询，支持主域名和所有子域名"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <RadioGroup
                android:id="@+id/dnsMatchTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/dnsMatchSingle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="域名"
                    android:checked="true"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/dnsMatchList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="域名列表"
                    android:visibility="gone" />

            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/dnsExpressionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="规则表达式"
                app:helperText='如: dns.fqdn == "example.com" or dns.fqdn matches ".*\.example\.com"'>

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dnsExpressionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:fontFamily="monospace"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/dnsListSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="点击选择列表"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/list_selector_background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/dnsListNotInCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="反向匹配 (not in list)"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- HTTP 规则字段 -->
        <LinearLayout
            android:id="@+id/httpFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP 规则"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="匹配网站访问，支持主机名和 URL 路径"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/httpExpressionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="规则表达式"
                app:helperText='如: http.request.host == "example.com" and http.request.uri.path matches "/api/*"'>

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/httpExpressionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:fontFamily="monospace"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <RadioGroup
                android:id="@+id/httpMatchTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/httpMatchSingle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="主机"
                    android:checked="true"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/httpMatchDomainList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="域名列表"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/httpMatchUrlList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="URL列表"
                    android:visibility="gone" />

            </RadioGroup>

            <TextView
                android:id="@+id/httpDomainListSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="点击选择列表"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/list_selector_background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/httpDomainListNotInCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="反向匹配 (not in list)"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/httpUrlListSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="点击选择列表"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/list_selector_background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/httpUrlListNotInCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="反向匹配 (not in list)"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/redirectUrlLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="策略URL重定向"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/redirectUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- L4 (Network) 规则字段 -->
        <LinearLayout
            android:id="@+id/l4Fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="网络规则"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="匹配网络层流量，支持 IP 地址和端口"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/l4ExpressionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="规则表达式"
                app:helperText='如: net.src.ip == 192.168.1.1 and net.dst.port == 443'>

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/l4ExpressionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:fontFamily="monospace"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <RadioGroup
                android:id="@+id/l4MatchTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/l4MatchSingle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="IP"
                    android:checked="true"
                    android:visibility="gone" />

                <RadioButton
                    android:id="@+id/l4MatchList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="IP列表"
                    android:visibility="gone" />

            </RadioGroup>

            <TextView
                android:id="@+id/l4ListSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="12dp"
                android:text="点击选择列表"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/list_selector_background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/l4ListNotInCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="反向匹配 (not in list)"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/l4OverrideIpLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="替代IP"
                app:helperText="例如: 192.168.1.1。可以是公共IP或连接到ZeroTrust网络的私有IP"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/l4OverrideIpInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/l4OverridePortLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="替代端口"
                app:helperText="例如: 8080"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/l4OverridePortInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 覆盖设置 (仅 DNS 规则 + override 动作) -->
        <LinearLayout
            android:id="@+id/overrideFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="覆盖设置"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="将匹配的 DNS 查询覆盖到指定目标（IP列表或单个主机名）"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <RadioGroup
                android:id="@+id/overrideTypeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/overrideIpList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="IP列表" />

                <RadioButton
                    android:id="@+id/overrideHostname"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="单个主机名" />

            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/overrideIpsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="IP列表 (每行一个IP)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/overrideIpsInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:minLines="2" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/overrideHostLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="主机名 (如: example.com)"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/overrideHostInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 流量表达式预览 -->
        <LinearLayout
            android:id="@+id/trafficPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="生成的规则表达式"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary" />

            <TextView
                android:id="@+id/trafficExpressionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="dns.fqdn == &quot;example.com&quot;"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:padding="8dp" />

        </LinearLayout>

        <!-- 优先级 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="优先级 (越小越高)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/precedenceInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="0" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 启用开关 -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/enabledSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:checked="true"
            android:text="启用规则" />

    </LinearLayout>

</ScrollView>