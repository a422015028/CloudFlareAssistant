<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="600dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="可视化表达式构建器"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- 条件列表容器 -->
        <LinearLayout
            android:id="@+id/conditionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addConditionBtn"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 添加条件"
            android:layout_marginBottom="8dp" />

        <!-- AND / OR 切换 -->
        <LinearLayout
            android:id="@+id/logicSwitchRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/logicChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <com.google.android.material.chip.Chip
                    android:id="@+id/andChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AND (全部满足)"
                    style="@style/Widget.Material3.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/orChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OR (任一满足)"
                    style="@style/Widget.Material3.Chip.Filter" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- 预览 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="预览"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/previewText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:background="?attr/colorSurfaceContainerHighest"
            android:padding="12dp"
            android:text="（请添加条件）"
            android:minHeight="48dp" />

    </LinearLayout>
</ScrollView>
