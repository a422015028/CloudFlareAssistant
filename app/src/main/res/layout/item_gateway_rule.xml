<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="8dp"
    android:layout_marginRight="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ruleNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="规则名称"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/ruleTypeChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_background"
                        android:paddingStart="5dp"
                        android:paddingTop="1dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="1dp"
                        android:text="DNS"
                        android:textColor="?attr/colorOnSecondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/ruleActionChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/chip_background"
                        android:paddingStart="5dp"
                        android:paddingTop="1dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="1dp"
                        android:text="阻止"
                        android:textColor="?attr/colorOnSecondary"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/enabledSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="匹配条件"
            android:textSize="10sp"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/ruleTrafficText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="dns.fqdn == &quot;example.com&quot;"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="?attr/colorPrimary"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:padding="2dp" />

        <TextView
            android:id="@+id/rulePrecedenceText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="优先级: 0"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="10sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/editButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:text="编辑"
                android:textSize="11sp" />

            <Button
                android:id="@+id/deleteButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="删除"
                android:textSize="11sp"
                android:textColor="?attr/colorError" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>