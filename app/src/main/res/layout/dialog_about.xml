<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- App Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_launcher" />

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/app_name"
        android:textColor="?attr/colorPrimary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Version -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:text="版本 5.3"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:background="?android:attr/listDivider" />

    <!-- TG Group -->
    <LinearLayout
        android:id="@+id/layoutTelegram"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📱 Telegram 群组"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTelegramLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加入讨论 →"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- GitHub -->
    <LinearLayout
        android:id="@+id/layoutGithub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌟 GitHub"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvGithubLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="查看源码 →"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />
    </LinearLayout>


    <!-- Cloudflare API 文档 -->
    <LinearLayout
        android:id="@+id/layoutCloudflareApi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌐 Cloudflare API 文档"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCloudflareApiLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="访问 →"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Cloudflare 官网 -->
    <LinearLayout
        android:id="@+id/layoutCloudflareWebsite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 Cloudflare 官网"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCloudflareWebsiteLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="访问 →"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 本应用官网 -->
    <LinearLayout
        android:id="@+id/layoutAppWebsite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚀 本应用官网"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAppWebsiteLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="访问 →"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 获取API令牌说明（可展开） -->
    <LinearLayout
        android:id="@+id/layoutApiTokenGuide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">
        <TextView
            android:id="@+id/tvApiTokenGuideTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔑 如何获取 Cloudflare API 令牌（点击展开）"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/tvApiTokenGuideContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="所需API权限: \n\n1. 登录 Cloudflare 仪表板\n2. 进入 我的个人资料 → API 令牌\n3. 点击 创建令牌\n4. 选择以下权限：\n\n【账户级别权限】\n   • Account Settings: 读取\n   • Workers Scripts: 编辑\n   • Workers Routes: 编辑\n   • Workers R2 Storage: 编辑\n   • Workers KV Storage: 编辑\n   • Cloudflare Pages: 编辑\n   • D1: 编辑\n   • Account Analytics: 读取\n\n【Zero Trust 权限】\n   • Zero Trust: 编辑\n   • Access: Apps and Policies: 编辑\n   • Access: Service Tokens: 编辑\n   • Gateway: 编辑\n   • Cloudflare Tunnel: 编辑\n\n【Zone 级别权限】\n   • Zone: 读取\n   • DNS: 编辑\n\n5. 账户资源选择：包含所有账户\n6. Zone资源选择：包含所有Zone\n7. 复制生成的 Token"
            android:textColor="?android:textColorSecondary"
            android:textSize="12sp"
            android:lineSpacingExtra="1dp"
            android:visibility="gone"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:background="?android:attr/listDivider" />

    <!-- Copyright -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="© 2025 CloudFlare Assistant\nMIT License"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp" />

</LinearLayout>

</ScrollView>
